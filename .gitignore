# ─── OS ───────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Editors ──────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

# ─── Node / npm ───────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*

# ─── Python ───────────────────────────────────
__pycache__/
*.pyc
.env
.venv/
venv/

# ─── Build outputs ────────────────────────────
dist/
build/
out/
*.log

# ─── Secrets / credentials ────────────────────
*.env
*.env.local
.env.*
secrets/
credentials/
*.pem
*.key

# ─── SSH private keys — NEVER COMMIT ──────────────────────────────────────────
_config/github_ed25519
*.enc
*.pat_key*

# ─── Sandbox artefacts ────────────────────────
sandboxes/**/data/
sandboxes/**/tmp/

# ─── Large binaries (use Git LFS instead) ─────
*.docx
*.pptx
*.xlsx
*.pdf
*.zip
*.tar.gz

# ─── Claude session temp files ────────────────
_sync/session-cache/
_sync/*.tmp
